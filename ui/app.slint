import { Theme, UISize, ButtonVariant } from "@ui/theme.slint";
import { Callbacks, Ui, Preview, Gifts, Detail, GiftRow, SaveBrowser, FileRow, Templates, TemplateRow } from "callbacks.slint";
import { Button } from "@ui/button.slint";
import { Icon } from "@ui/icon.slint";
import { Input } from "@ui/input.slint";
import { SegmentedControl } from "@ui/segmented_control.slint";

export { Callbacks, Ui, Preview, Gifts, Detail, GiftRow, SaveBrowser, FileRow, Templates, TemplateRow, Theme }

component PrimaryAction inherits Button {
    background: Theme.palette-primary;
    foreground: #ffffff;
    border-color: transparent;
    border-width: 0px;
    font-weight: 600;
    font-family: "Montserrat";
    button-opacity: self.disabled ? 0.5 : 1.0;
    touch-expansion: 4px;
    font-size: 20px;
    padding-horizontal: 20px;
    padding-vertical: 12px;
    icon-size: 20px;
    border-radius: 24px;
}

component SecondaryAction inherits Button {
    background: Theme.palette-secondary;
    foreground: Theme.palette-foreground;
    border-color: transparent;
    border-width: 0px;
    font-weight: 600;
    font-family: "Montserrat";
    touch-expansion: 4px;
    font-size: 20px;
    padding-horizontal: 20px;
    padding-vertical: 12px;
    icon-size: 20px;
    border-radius: 24px;
}

// Raw-TouchArea round button (the SDK IconButton mis-sizes its hit area).
component BackBtn inherits Rectangle {
    callback clicked();
    width: 44px;
    height: 44px;
    border-radius: 22px;
    background: touch.pressed ? Theme.palette-secondary-pressed : Theme.palette-secondary.with-alpha(0.4);
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
    Text {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2 - 2px;
        text: "‹";
        color: Theme.palette-foreground;
        font-size: 28px;
        font-family: "Montserrat";
    }
}

// Home-screen variant option row.
component VariantOption inherits Rectangle {
    in property <int> index;
    in property <string> name;
    in property <string> detail;
    height: 72px;
    border-radius: 16px;
    background: Ui.variant-index == index
        ? Theme.palette-secondary
        : Theme.palette-secondary.with-alpha(0.3);
    TouchArea {
        clicked => { Ui.variant-index = index; }
    }
    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 12px;
        Rectangle {
            width: 22px;
            y: (parent.height - self.height) / 2;
            height: 22px;
            border-radius: 11px;
            border-width: 2px;
            border-color: Ui.variant-index == index ? Theme.palette-primary : Theme.palette-muted;
            background: transparent;
            if Ui.variant-index == index: Rectangle {
                x: 5px;
                y: 5px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: Theme.palette-primary;
            }
        }
        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text {
                text: root.name;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 17px;
                font-weight: 600;
            }
            Text {
                text: root.detail;
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }
        }
    }
}

// Modal name prompt (text-editor pattern): anchored high so the on-screen
// keyboard (~396px) never covers it; keyboard "Done" confirms.
component NamePrompt inherits Rectangle {
    in property <string> title;
    in property <string> confirm-label;
    in property <string> placeholder: "Name";
    callback confirmed(string);
    callback cancelled();

    background: rgba(0, 0, 0, 0.55);

    TouchArea {
        clicked => { root.cancelled(); }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: 96px;
        width: 86%;
        height: 214px;
        background: Theme.palette-surface;
        border-radius: 16px;
        border-width: 1px;
        border-color: Theme.palette-border;

        // Swallow taps on the panel so they don't dismiss.
        TouchArea {}

        VerticalLayout {
            padding: 24px;
            spacing: 16px;

            Text {
                text: root.title;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 20px;
                font-weight: 600;
            }
            Input {
                value <=> Ui.input-text;
                placeholder: root.placeholder;
                submitted => {
                    self.clear-focus();
                    root.confirmed(Ui.input-text);
                }
            }
            HorizontalLayout {
                spacing: 12px;
                SecondaryAction {
                    horizontal-stretch: 1;
                    text: "Cancel";
                    clicked => { root.cancelled(); }
                }
                PrimaryAction {
                    horizontal-stretch: 1;
                    text: root.confirm-label;
                    clicked => { root.confirmed(Ui.input-text); }
                }
            }
        }
    }
}

// One row in the save-browser listing (folders descend; files are context).
component SaveEntry inherits Rectangle {
    in property <FileRow> entry;
    height: 56px;
    border-radius: 12px;
    background: touch.has-hover ? Theme.palette-secondary : Theme.palette-secondary.with-alpha(0.2);
    touch := TouchArea {
        clicked => { Callbacks.save-entry-activated(root.entry.name, root.entry.is-folder); }
    }
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 10px;
        Image {
            width: 22px;
            y: (parent.height - self.height) / 2;
            height: 22px;
            source: root.entry.is-folder ? @image-url("icons/folder.svg") : @image-url("icons/file.svg");
            colorize: root.entry.is-folder ? Theme.palette-primary : Theme.palette-muted;
        }
        Text {
            text: root.entry.name;
            color: root.entry.is-folder ? Theme.palette-foreground : Theme.palette-muted;
            font-family: "Montserrat";
            font-size: 15px;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        Text {
            text: root.entry.info;
            color: Theme.palette-muted;
            font-family: "Montserrat";
            font-size: 12px;
            vertical-alignment: center;
        }
    }
}

// One row in the bill-design picker (radio-style, like VariantOption).
component TemplateEntry inherits Rectangle {
    in property <TemplateRow> entry;
    in property <int> index;
    height: 64px;
    border-radius: 14px;
    background: root.entry.selected
        ? Theme.palette-secondary
        : Theme.palette-secondary.with-alpha(0.3);
    TouchArea {
        clicked => { Callbacks.pick-template(root.index); }
    }
    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 12px;
        Rectangle {
            width: 22px;
            y: (parent.height - self.height) / 2;
            height: 22px;
            border-radius: 11px;
            border-width: 2px;
            border-color: root.entry.selected ? Theme.palette-primary : Theme.palette-muted;
            background: transparent;
            if root.entry.selected: Rectangle {
                x: 5px;
                y: 5px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: Theme.palette-primary;
            }
        }
        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text {
                text: root.entry.name;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 16px;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: root.entry.location;
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
            }
        }
    }
}

component GiftEntry inherits Rectangle {
    in property <GiftRow> entry;
    height: 64px;
    border-radius: 12px;
    background: touch.has-hover ? Theme.palette-secondary : Theme.palette-secondary.with-alpha(0.25);
    touch := TouchArea {
        clicked => { Callbacks.open-gift(root.entry.filename); }
    }
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 10px;
        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text {
                text: root.entry.address;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 15px;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: root.entry.subtitle;
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
            }
        }
        if root.entry.has-backup: Rectangle {
            width: 58px;
            height: 22px;
            y: (parent.height - self.height) / 2;
            border-radius: 11px;
            background: Theme.palette-primary.with-alpha(0.25);
            Text {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                text: "backup";
                color: Theme.palette-primary;
                font-family: "Montserrat";
                font-size: 11px;
                font-weight: 600;
            }
        }
        Text {
            width: 14px;
            text: "›";
            color: Theme.palette-muted;
            font-size: 22px;
            vertical-alignment: center;
        }
    }
}

export component AppWindow inherits Window {
    title: "Paper Wallet";
    preferred-width: 480px;
    preferred-height: 800px;
    background: Theme.palette-background;

    root-container := Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.palette-background;

        // ------------------------------------------------ screen 0: home
        if Ui.screen == 0: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 24px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 14px;

            Text {
                text: "Paper Wallet";
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 26px;
                font-weight: 700;
                horizontal-alignment: center;
            }
            Text {
                text: "Bitcoin gift bills — generated offline, keys never derived from your wallet seed";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            VariantOption {
                index: 0;
                name: "SegWit";
                detail: "bc1q… bill, sweeps in any wallet";
            }
            VariantOption {
                index: 1;
                name: "Taproot";
                detail: "bc1p… bill, BIP86-compatible key";
            }
            VariantOption {
                index: 2;
                name: "Taproot + backup";
                detail: "Two spend paths: printed key, plus a backup key on this device";
            }

            Rectangle { vertical-stretch: 1; }

            Text {
                text: Ui.error != "" ? Ui.error : Ui.info;
                color: Ui.error != "" ? #e05050 : Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            bill-design-row := Rectangle {
                height: 56px;
                border-radius: 14px;
                background: Theme.palette-secondary.with-alpha(0.35);
                TouchArea {
                    clicked => { Callbacks.open-template-picker(); }
                }
                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    Text {
                        text: "Bill design: " + Templates.selected-name;
                        color: Theme.palette-foreground;
                        font-family: "Montserrat";
                        font-size: 16px;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: "›";
                        color: Theme.palette-muted;
                        font-size: 22px;
                        vertical-alignment: center;
                    }
                }
            }

            saved-gifts-row := Rectangle {
                height: 56px;
                border-radius: 14px;
                background: Theme.palette-secondary.with-alpha(0.35);
                TouchArea {
                    clicked => {
                        Callbacks.refresh-gifts();
                        Ui.screen = 2;
                    }
                }
                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    Text {
                        text: "Saved gifts (" + Ui.gift-count + ")";
                        color: Theme.palette-foreground;
                        font-family: "Montserrat";
                        font-size: 16px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Text {
                        text: "›";
                        color: Theme.palette-muted;
                        font-size: 22px;
                        vertical-alignment: center;
                    }
                }
            }

            PrimaryAction {
                width: 100%;
                text: "Generate";
                disabled: Ui.busy;
                clicked => { Callbacks.generate(Ui.variant-index); }
            }
        }

        // ------------------------------------------------ screen 1: preview
        if Ui.screen == 1: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 20px;
            spacing: 8px;

            Text {
                text: Preview.variant-name;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 20px;
                font-weight: 700;
                horizontal-alignment: center;
            }

            HorizontalLayout {
                alignment: center;
                Image {
                    width: 190px;
                    height: 190px;
                    source: Preview.address-qr;
                }
            }
            Text {
                text: "DEPOSIT — " + Preview.address;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 13px;
                horizontal-alignment: center;
                wrap: char-wrap;
            }

            HorizontalLayout {
                alignment: center;
                Image {
                    width: 190px;
                    height: 190px;
                    source: Preview.sweep-qr;
                }
            }
            Text {
                text: "SPEND (sweep link)" + (Preview.is-tweaked ? " — tweaked key" : "");
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 12px;
                horizontal-alignment: center;
            }
            Text {
                text: Preview.bill-wif;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 12px;
                horizontal-alignment: center;
                wrap: char-wrap;
            }
            if Preview.has-backup: Text {
                text: "Backup spend path: key #" + Preview.backup-index + " (seed-derived, recoverable on this device)";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 12px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
            if Preview.saved: Text {
                text: "Saved to " + Preview.saved-path;
                color: Theme.palette-primary;
                font-family: "Montserrat";
                font-size: 12px;
                horizontal-alignment: center;
                wrap: char-wrap;
            }
            Text {
                text: Ui.error;
                color: #e05050;
                font-family: "Montserrat";
                font-size: 12px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Rectangle { vertical-stretch: 1; }

            HorizontalLayout {
                spacing: 12px;
                SecondaryAction {
                    horizontal-stretch: 1;
                    text: Preview.saved ? "Done" : "Discard";
                    disabled: Ui.busy;
                    clicked => { Callbacks.discard(); }
                }
                PrimaryAction {
                    horizontal-stretch: 1;
                    text: Preview.saved ? "Saved" : "Save bill";
                    disabled: Ui.busy || Preview.saved;
                    clicked => { Callbacks.open-save-browser(); }
                }
            }
        }

        // ------------------------------------------------ screen 2: saved gifts
        if Ui.screen == 2: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 12px;

            HorizontalLayout {
                spacing: 12px;
                BackBtn {
                    clicked => { Ui.screen = 0; }
                }
                Text {
                    text: "Saved gifts";
                    color: Theme.palette-foreground;
                    font-family: "Montserrat";
                    font-size: 22px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
            }

            if Gifts.status != "": Text {
                text: Gifts.status;
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 14px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Flickable {
                vertical-stretch: 1;
                viewport-height: gift-list.preferred-height;
                gift-list := VerticalLayout {
                    spacing: 8px;
                    alignment: start;
                    for gift in Gifts.gifts: GiftEntry { entry: gift; }
                }
            }
        }

        // ------------------------------------------------ screen 3: gift detail
        if Ui.screen == 3: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 10px;

            HorizontalLayout {
                spacing: 12px;
                BackBtn {
                    clicked => {
                        Detail.show-backup = false;
                        Ui.screen = 2;
                    }
                }
                Text {
                    text: Detail.type-name;
                    color: Theme.palette-foreground;
                    font-family: "Montserrat";
                    font-size: 20px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
            }

            Text {
                text: Detail.address;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 14px;
                wrap: char-wrap;
            }
            Text {
                text: "Created " + Detail.created-at;
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
            }
            if Detail.bill-path != "": Text {
                text: "Bill saved to " + Detail.bill-path;
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: char-wrap;
            }
            Text {
                text: "Internal pubkey (needed for recovery)";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
            }
            Text {
                text: Detail.internal-pubkey;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 12px;
                wrap: char-wrap;
            }

            if Detail.show-backup: VerticalLayout {
                spacing: 8px;
                Text {
                    text: "Backup key #" + Detail.backup-index + " (WIF)";
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 13px;
                }
                Text {
                    text: Detail.backup-wif;
                    color: Theme.palette-foreground;
                    font-family: "Montserrat";
                    font-size: 12px;
                    wrap: char-wrap;
                }
                HorizontalLayout {
                    alignment: center;
                    Image {
                        width: 170px;
                        height: 170px;
                        source: Detail.backup-qr;
                    }
                }
                Text {
                    text: "Recover: open recover.html in the web app, enter this WIF + the internal pubkey above";
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }

            Text {
                text: Ui.error;
                color: #e05050;
                font-family: "Montserrat";
                font-size: 12px;
                wrap: word-wrap;
            }

            Rectangle { vertical-stretch: 1; }

            if Detail.has-backup && !Detail.show-backup: PrimaryAction {
                width: 100%;
                text: "Show backup key";
                disabled: Ui.busy;
                clicked => { Callbacks.backup-view(); }
            }
        }

        // ------------------------------------------------ screen 4: save browser
        if Ui.screen == 4: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 20px;
            spacing: 10px;

            HorizontalLayout {
                spacing: 12px;
                BackBtn {
                    clicked => {
                        Ui.show-new-folder = false;
                        Ui.screen = 1;
                    }
                }
                Text {
                    text: "Save bill";
                    color: Theme.palette-foreground;
                    font-family: "Montserrat";
                    font-size: 22px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
            }

            // Filename near the top: the on-screen keyboard (~396px) never
            // covers it, and "Done" just drops the keyboard. vertical-stretch 0
            // keeps the header block pinned when the listing is empty (all
            // spare space must go to the Flickable, or tap targets shift).
            Input {
                vertical-stretch: 0;
                value <=> SaveBrowser.filename;
                placeholder: "File name";
                submitted => { self.clear-focus(); }
            }
            Text {
                text: "Saves " + SaveBrowser.filename + ".png + .json";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 12px;
            }

            HorizontalLayout {
                height: 64px;
                spacing: 8px;
                SegmentedControl {
                    horizontal-stretch: 1;
                    options: ["Internal", "Airlock", "USB"];
                    selected-index <=> SaveBrowser.location-index;
                    changed(idx, label) => {
                        Callbacks.save-location-changed(idx);
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;
                if !SaveBrowser.at-root: BackBtn {
                    clicked => { Callbacks.save-go-back(); }
                }
                Text {
                    text: SaveBrowser.path;
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 14px;
                    vertical-alignment: center;
                    overflow: elide;
                    horizontal-stretch: 1;
                }
                new-folder-btn := Rectangle {
                    width: 44px;
                    height: 44px;
                    border-radius: 22px;
                    background: nf-touch.pressed ? Theme.palette-secondary-pressed : Theme.palette-secondary.with-alpha(0.4);
                    nf-touch := TouchArea {
                        clicked => {
                            Ui.input-text = "";
                            Ui.show-new-folder = true;
                        }
                    }
                    Text {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2 - 2px;
                        text: "+";
                        color: Theme.palette-foreground;
                        font-size: 26px;
                        font-family: "Montserrat";
                    }
                }
            }

            if SaveBrowser.status != "": Text {
                text: SaveBrowser.status;
                color: #e05050;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }
            if Ui.error != "": Text {
                text: Ui.error;
                color: #e05050;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }

            Flickable {
                vertical-stretch: 1;
                viewport-height: save-list.preferred-height;
                save-list := VerticalLayout {
                    spacing: 6px;
                    alignment: start;
                    for entry in SaveBrowser.entries: SaveEntry { entry: entry; }
                }
            }

            HorizontalLayout {
                spacing: 12px;
                SecondaryAction {
                    horizontal-stretch: 1;
                    text: "Cancel";
                    disabled: Ui.busy;
                    clicked => {
                        Ui.show-new-folder = false;
                        Ui.screen = 1;
                    }
                }
                PrimaryAction {
                    horizontal-stretch: 1;
                    text: "Save here";
                    disabled: Ui.busy || SaveBrowser.status != "";
                    clicked => { Callbacks.save-confirm(SaveBrowser.filename); }
                }
            }
        }

        // ------------------------------------------------ screen 5: bill design
        if Ui.screen == 5: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 12px;

            HorizontalLayout {
                vertical-stretch: 0;
                spacing: 12px;
                BackBtn {
                    clicked => { Ui.screen = 0; }
                }
                Text {
                    text: "Bill design";
                    color: Theme.palette-foreground;
                    font-family: "Montserrat";
                    font-size: 22px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
            }

            Text {
                vertical-stretch: 0;
                text: "Custom designs are PNGs in /paper-wallets/templates on Internal or Airlock storage. Export the design kit for the blank template and a working example.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }

            if Templates.status != "": Text {
                vertical-stretch: 0;
                text: Templates.status;
                color: Theme.palette-primary;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }
            if Ui.error != "": Text {
                vertical-stretch: 0;
                text: Ui.error;
                color: #e05050;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }

            Flickable {
                vertical-stretch: 1;
                viewport-height: template-list.preferred-height;
                template-list := VerticalLayout {
                    spacing: 8px;
                    alignment: start;
                    for t[i] in Templates.rows: TemplateEntry {
                        entry: t;
                        index: i;
                    }
                }
            }

            PrimaryAction {
                width: 100%;
                text: "Export design kit to Airlock";
                disabled: Ui.busy;
                clicked => { Callbacks.export-design-kit(); }
            }
        }

        // ------------------------------------------------ new-folder prompt
        if Ui.show-new-folder: NamePrompt {
            width: 100%;
            height: 100%;
            title: "New folder";
            confirm-label: "Create";
            placeholder: "Folder name";
            confirmed(name) => {
                Ui.show-new-folder = false;
                Callbacks.save-new-folder(name);
            }
            cancelled => {
                Ui.show-new-folder = false;
            }
        }

        // ------------------------------------------------ busy overlay
        if Ui.busy: Rectangle {
            width: parent.width;
            height: parent.height;
            background: Theme.palette-background.with-alpha(0.75);
            TouchArea {}
            Text {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                text: "Working…";
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 20px;
                font-weight: 600;
            }
        }
    }
}
